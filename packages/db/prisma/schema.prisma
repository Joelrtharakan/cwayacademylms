generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}



















model User {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  passwordHash      String?
  role              String      @default("STUDENT")
  avatar            String?
  bio               String?
  phone             String?
  church            String?
  location          String?
  preferredLanguage String  @default("ENGLISH")
  isVerified        Boolean   @default(false)
  isBanned          Boolean   @default(false)
  payoutPercentage  Float     @default(70)
  emailVerifyToken  String?
  resetToken        String?
  resetTokenExpiry  DateTime?
  googleId          String?   @unique
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  coursesCreated    Course[]       @relation("InstructorCourses")
  enrollments       Enrollment[]
  quizAttempts      QuizAttempt[]
  submissions       Submission[]
  certificates      Certificate[]
  reviews           Review[]
  forumPosts        ForumPost[]
  forumReplies      ForumReply[]
  sentMessages      Message[]      @relation("SentMessages")
  receivedMessages  Message[]      @relation("ReceivedMessages")
  notifications     Notification[]
  payments          Payment[]
  sponsorships      Sponsorship[]
  blogPosts         BlogPost[]
  payoutRequests    PayoutRequest[]
  socialLinks       String? // JSON: { twitter, linkedin, website }
  title             String?  // e.g. "Dr."
  credentials       String?  // e.g. "M.Th., Ph.D."
  yearsExperience   Int?
  expertise         String  @default("[]")
  notificationPrefs String  @default("{}")

  @@index([email])
  @@index([role])
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  icon      String?
  order     Int        @default(0)
  parentId  String?
  parent    Category?  @relation("Subcategories", fields: [parentId], references: [id])
  children  Category[] @relation("Subcategories")
  courses   Course[]
  createdAt DateTime   @default(now())
}

model Course {
  id               String       @id @default(cuid())
  title            String
  slug             String       @unique
  subtitle         String?
  description      String?      
  thumbnail        String?
  promoVideoUrl    String?
  price            Float        @default(0)
  currency         String       @default("INR")
  status           String @default("DRAFT")
  level            String  @default("BEGINNER")
  language         String     @default("ENGLISH")
  moduleNumber     Int?
  weeksDuration    Int          @default(6)
  totalLectures    Int          @default(0)
  totalDuration    Int          @default(0) // seconds
  scriptureRef     String?
  isFeatured       Boolean      @default(false)
  isFree           Boolean      @default(true)
  requirements     String @default("[]")
  outcomes         String @default("[]")
  targetAudience   String @default("[]")
  welcomeMessage   String?
  congratsMessage  String?
  tags             String @default("[]")
  rejectionReason  String?

  instructorId String
  instructor   User     @relation("InstructorCourses", fields: [instructorId], references: [id])
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])

  sections    Section[]
  enrollments Enrollment[]
  reviews     Review[]
  forum       Forum?
  payments    Payment[]
  coupons     Coupon[]
  certificate Certificate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([instructorId])
  @@index([slug])
}

model Section {
  id       String   @id @default(cuid())
  courseId String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title    String
  order    Int
  lessons  Lesson[]

  @@index([courseId])
}

model Lesson {
  id          String     @id @default(cuid())
  sectionId   String
  section     Section    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  title       String
  type        String
  content     String?    
  videoUrl    String?
  duration    Int        @default(0) // seconds
  order       Int
  isFree      Boolean    @default(false)
  isPreview   Boolean    @default(false)
  bunnyVideoId String?

  quiz        Quiz?
  assignment  Assignment?
  progress    LessonProgress[]

  @@index([sectionId])
}

model Enrollment {
  id          String           @id @default(cuid())
  studentId   String
  student     User             @relation(fields: [studentId], references: [id])
  courseId    String
  course      Course           @relation(fields: [courseId], references: [id])
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  progress    Float            @default(0)
  status      String @default("ACTIVE")
  paymentId   String?
  payment     Payment?         @relation(fields: [paymentId], references: [id])
  sponsorshipId String?

  lessonProgress LessonProgress[]

  @@unique([studentId, courseId])
  @@index([studentId])
  @@index([courseId])
}

model LessonProgress {
  id           String     @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lessonId     String
  lesson       Lesson     @relation(fields: [lessonId], references: [id])
  completedAt  DateTime?
  watchedSeconds Int      @default(0)

  @@unique([enrollmentId, lessonId])
}

model Quiz {
  id           String        @id @default(cuid())
  lessonId     String        @unique
  lesson       Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title        String
  passingScore Int           @default(70)
  timeLimit    Int?          // seconds, null = no limit
  maxAttempts  Int           @default(3)
  questions    Question[]
  attempts     QuizAttempt[]
}

model Question {
  id           String       @id @default(cuid())
  quizId       String
  quiz         Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  text         String       
  type         String @default("MCQ")
  points       Int          @default(1)
  order        Int
  scriptureRef String?
  answers      Answer[]

  @@index([quizId])
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean  @default(false)
}

model QuizAttempt {
  id          String    @id @default(cuid())
  quizId      String
  quiz        Quiz      @relation(fields: [quizId], references: [id])
  studentId   String
  student     User      @relation(fields: [studentId], references: [id])
  score       Float     @default(0)
  passed      Boolean   @default(false)
  answers     String      // { questionId: answerId }
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([quizId, studentId])
}

model Assignment {
  id            String       @id @default(cuid())
  lessonId      String       @unique
  lesson        Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title         String
  description   String       
  dueDate       DateTime?
  maxScore      Int          @default(100)
  attachmentUrl String?
  submissions   Submission[]
}

model Submission {
  id           String     @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  studentId    String
  student      User       @relation(fields: [studentId], references: [id])
  content      String?    
  fileUrl      String?
  submittedAt  DateTime   @default(now())
  grade        Float?
  feedback     String?    
  gradedAt     DateTime?
  isGraded     Boolean    @default(false)

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
}

model Certificate {
  id             String    @id @default(cuid())
  studentId      String
  student        User      @relation(fields: [studentId], references: [id])
  courseId       String
  course         Course    @relation(fields: [courseId], references: [id])
  issuedAt       DateTime  @default(now())
  uniqueCode     String    @unique @default(cuid())
  downloadUrl    String?
  templateId     String?
  template       CertificateTemplate? @relation(fields: [templateId], references: [id])

  @@unique([studentId, courseId])
}

model CertificateTemplate {
  id                   String        @id @default(cuid())
  name                 String
  htmlTemplate         String        
  isDefault            Boolean       @default(false)
  logoUrl              String?
  signatorySignatureUrl String?
  borderStyle          String?
  createdAt            DateTime      @default(now())
  certificates         Certificate[]
}

model Review {
  id         String   @id @default(cuid())
  courseId   String
  course     Course   @relation(fields: [courseId], references: [id])
  studentId  String
  student    User     @relation(fields: [studentId], references: [id])
  rating     Int      // 1-5
  comment    String?  
  isApproved Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@unique([courseId, studentId])
  @@index([courseId])
}

model Forum {
  id       String      @id @default(cuid())
  courseId String      @unique
  course   Course      @relation(fields: [courseId], references: [id])
  posts    ForumPost[]
}

model ForumPost {
  id        String       @id @default(cuid())
  forumId   String
  forum     Forum        @relation(fields: [forumId], references: [id])
  authorId  String
  author    User         @relation(fields: [authorId], references: [id])
  title     String
  content   String       
  isPinned  Boolean      @default(false)
  replies   ForumReply[]
  createdAt DateTime     @default(now())

  @@index([forumId])
}

model ForumReply {
  id        String    @id @default(cuid())
  postId    String
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id])
  content   String    
  createdAt DateTime  @default(now())

  @@index([postId])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  content    String   
  sentAt     DateTime @default(now())
  readAt     DateTime?

  @@index([senderId, receiverId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

model Payment {
  id              String        @id @default(cuid())
  studentId       String
  student         User          @relation(fields: [studentId], references: [id])
  courseId        String
  course          Course        @relation(fields: [courseId], references: [id])
  amount          Float
  currency        String        @default("INR")
  stripePaymentId String?       @unique
  status          String @default("PENDING")
  isSponsored     Boolean       @default(false)
  createdAt       DateTime      @default(now())
  enrollments     Enrollment[]
}

model Sponsorship {
  id              String        @id @default(cuid())
  sponsorName     String
  sponsorEmail    String
  amount          Float
  currency        String        @default("INR")
  stripePaymentId String?       @unique
  status          String @default("PENDING")
  message         String?
  studentId       String?
  student         User?         @relation(fields: [studentId], references: [id])
  courseId        String?
  createdAt       DateTime      @default(now())
}

model Coupon {
  id        String     @id @default(cuid())
  code      String     @unique
  discount  Float
  type      String
  maxUses   Int        @default(100)
  usedCount Int        @default(0)
  expiresAt DateTime?
  courseId  String?
  course    Course?    @relation(fields: [courseId], references: [id])
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  subject   String
  htmlBody  String   
  variables String @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  id             String   @id @default(cuid())
  siteName       String   @default("CWAY Academy")
  logoUrl        String?
  tagline        String?
  contactEmail   String?
  contactWhatsApp String?
  primaryColor   String   @default("#C9973A")
  smtpConfig     String?
  stripeConfig   String?
  storageConfig  String?
  updatedAt      DateTime @updatedAt
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String   
  coverImage  String?
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  isPublished Boolean  @default(false)
  readingTime Int?     // minutes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

model PayoutRequest {
  id           String   @id @default(cuid())
  instructorId String
  instructor   User     @relation(fields: [instructorId], references: [id])
  amount       Float
  currency     String   @default("INR")
  status       String   @default("PENDING")
  bankDetails  String?
  note         String?
  adminNote    String?
  requestedAt  DateTime @default(now())
  resolvedAt   DateTime?

  @@index([instructorId])
}
